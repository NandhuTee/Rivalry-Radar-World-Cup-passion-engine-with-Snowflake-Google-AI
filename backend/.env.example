# Copy to .env and fill in — or export these directly in your shell.
# Leaving SNOWFLAKE_ACCOUNT unset makes the API boot in DEMO MODE with seed data.

# --- Google AI (Gemini) — does the sentiment scoring + Hype Verdict text ---
# Free key, no card required: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- Snowflake — stores every take, computes the Heat Index + leaderboards ---
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
# Or, for key-pair auth instead of a password:
# SNOWFLAKE_PRIVATE_KEY_FILE=/path/to/rsa_key.p8

SNOWFLAKE_ROLE=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=



